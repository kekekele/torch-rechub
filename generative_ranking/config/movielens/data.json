{
  "dataset": "movielens",
  "dataset_display_name": "MovieLens-1M",
  "data_dir": "./generative_ranking/data/ml-1m/",
  "source": {
    "base_table": "interactions",
    "tables": {
      "interactions": {
        "path": "seq.csv",
        "read_csv": {
          "sep": ",",
          "header": 0,
          "encoding": "utf-8"
        },
        "select_columns": ["uid", "iid", "timestamp", "label"]
      },
      "users": {
        "path": "user_info.csv",
        "read_csv": {
          "sep": ",",
          "header": 0,
          "encoding": "utf-8"
        },
        "select_columns": ["uid", "gender", "age", "occupation", "zip_code"]
      },
      "items": {
        "path": "item_fea.csv",
        "read_csv": {
          "sep": ",",
          "header": 0,
          "encoding": "utf-8"
        },
        "select_columns": ["iid", "title", "genres"]
      }
    },
    "joins": [
      {
        "right_table": "users",
        "left_on": "uid",
        "right_on": "uid",
        "how": "left"
      },
      {
        "right_table": "items",
        "left_on": "iid",
        "right_on": "iid",
        "how": "left"
      }
    ],
    "select_columns": ["uid", "iid", "gender", "age", "occupation", "zip_code", "title", "genres", "timestamp", "label"]
  },
  "dataset_params": {
    "max_seq_len": 101
  },
  "sample_builder": {
    "user_id_col": "uid",
    "timestamp_col": "timestamp",
    "label_col": "label",
    "max_seq_len": 101,
    "history_filter": {
      "positive_only": true
    },
    "split": {
      "type": "global_time_ratio",
      "ratios": [0.8, 0.1, 0.1]
    }
  },
  "features": {
    "user_sparse": [
      "uid",
      "gender",
      "age",
      "occupation",
      "zip_code"
    ],
    "user_dense": [],
    "item_sparse": [
      {
        "name": "target_item_id",
        "source": "iid"
      }
    ],
    "item_dense": [
    ],
    "item_sequence": [
      {
        "name": "target_genres",
        "source": "genres",
        "rankmixer_pooling": "mean",
        "dcn_pooling": "mean",
        "value_sep": ","
      }
    ],
    "sequence": [
      {
        "name": "hist_item_id",
        "source": "iid",
        "shared_with": "target_item_id",
        "rankmixer_pooling": "concat",
        "dcn_pooling": "mean"
      }
    ],
    "embedding_dim": 16,
    "padding_idx": 0
  },
  "semantic_schema": [
    {
      "name": "user_profile",
      "features": ["uid", "gender", "age", "occupation", "zip_code"]
    },
    {
      "name": "target_item",
      "features": ["target_item_id", "target_genres"]
    },
    {
      "name": "sequence_global",
      "sequence_features": ["hist_item_id"],
      "pool_modes": ["mean"]
    },
    {
      "name": "sequence_target",
      "sequence_features": ["hist_item_id"],
      "pool_modes": ["target"]
    }
  ]
}